<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Perfil - AgendaiFisio</title>
    <link rel="stylesheet" href="index.css">
    <style>
        /* ── Estilos adicionais para a página de perfil ── */
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.95rem;
        }
        .info-row:last-child { border-bottom: none; }
        .info-row span:first-child { color: var(--texto-muted); font-weight: 600; }
        .info-row span:last-child { color: var(--texto); font-weight: 700; }

        .avatar-grande {
            width: 80px; height: 80px;
            background: var(--brand);
            color: white;
            border-radius: 50%;
            display: grid; place-items: center;
            font-size: 2rem;
            font-weight: 900;
            margin: 0 auto 1.5rem;
            box-shadow: 0 8px 24px rgba(167,194,126,0.4);
        }

        .card-perfil-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .card-perfil-header h2 { margin: 0 0 0.25rem; font-size: 1.4rem; }
        .card-perfil-header p { margin: 0; color: var(--texto-muted); font-size: 0.9rem; }

        .tag-status {
            display: inline-block;
            background: #dcfce7;
            color: #16a34a;
            border-radius: 100px;
            padding: 4px 14px;
            font-size: 0.8rem;
            font-weight: 700;
            margin-top: 0.5rem;
        }

        .consulta-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 14px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            margin-bottom: 12px;
            transition: var(--transition);
        }
        .consulta-item:hover { border-color: var(--brand); background: #fff; }
        .consulta-item .consulta-data { font-size: 0.8rem; color: var(--texto-muted); font-weight: 600; }
        .consulta-item .consulta-medico { font-weight: 800; color: var(--texto); font-size: 0.95rem; }
        .consulta-item .consulta-status {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            width: fit-content;
        }
        .status-confirmada { background: #dcfce7; color: #16a34a; }
        .status-concluida  { background: #e0f2fe; color: #0284c7; }
        .status-cancelada  { background: #fee2e2; color: #dc2626; }

        .empty-state {
            text-align: center;
            color: var(--texto-muted);
            padding: 2rem 0;
            font-size: 0.9rem;
        }
        .empty-state span { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }

        .btn-editar {
            width: 100%;
            padding: 0.85rem;
            margin-top: 1.5rem;
            border-radius: 14px;
            border: 2px solid var(--brand);
            background: transparent;
            color: var(--brand);
            font-weight: 800;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
        }
        .btn-editar:hover { background: var(--brand); color: white; }

        .btn-agendar-link {
            width: 100%;
            padding: 0.85rem;
            margin-top: 0.75rem;
            border-radius: 14px;
            border: none;
            background: var(--brand);
            color: white;
            font-weight: 800;
            font-size: 1rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }
        .btn-agendar-link:hover { filter: brightness(1.1); transform: scale(1.02); }
    </style>
</head>
<body>

    <!-- Header com Menu de Conta (idêntico ao index.html) -->
    <header class="navbar">
        <div class="logo">
            <img src="Logo.png" alt="logo" class="logo-site">
            <h1>AgendaiFisio</h1>
        </div>

        <div class="perfil-container" id="perfilMenu">
            <div class="avatar">DG</div>
            <div class="dropdown-conta">
                <div class="user-header">
                    <strong>Davi Gusmão</strong>
                    <span>davigusmao@email.com</span>
                </div>
                <hr>
                <a href="TelaPaciente.html">👤 Ver Meu Perfil</a>
                <a href="../Tela Consulta Paciente/TelaPaciente.html">📅 Minhas Consultas</a>
                <a href="../tela de login/login.html" class="logout">🚪 Sair</a>
            </div>
        </div>
    </header>

    <main class="container-agendamento">
        <h1 class="titulo-sessao">Minha Conta</h1>

        <div class="cards-grid">

            <!-- Card 1: Dados Pessoais -->
            <article class="card-moderno card-paciente">
                <span class="badge">Dados Pessoais</span>

                <div class="card-perfil-header">
                    <div class="avatar-grande">DG</div>
                    <h2>Davi Gusmão</h2>
                    <p>davigusmao@email.com</p>
                    <span class="tag-status">✅ Paciente Ativo</span>
                </div>

                <div class="info-row">
                    <span>CPF</span>
                    <span>•••.•••.123-00</span>
                </div>
                <div class="info-row">
                    <span>Data de Nascimento</span>
                    <span>15/03/2006</span>
                </div>
                <div class="info-row">
                    <span>Telefone</span>
                    <span>(11) 9 9999-8888</span>
                </div>
                <div class="info-row">
                    <span>Plano</span>
                    <span>Plano Liberado</span>
                </div>
                <div class="info-row">
                    <span>Membro desde</span>
                    <span>Novembro/2025</span>
                </div>

                <button class="btn-editar">✏️ Editar Dados</button>
            </article>

            <!-- Card 2: Minhas Consultas -->
            <article class="card-moderno card-fisioterapeuta">
                <span class="badge">Minhas Consultas</span>
                <h2>Histórico de Sessões</h2>

                <!-- Próxima consulta -->
                <div class="consulta-item">
                    <span class="consulta-data">📅 28/05/2026 às 10:00</span>
                    <span class="consulta-medico">Dr. Davi Vinciaqui — Esportiva</span>
                    <span class="consulta-status status-confirmada">✔ Confirmada</span>
                </div>

                <!-- Consultas passadas -->
                <div class="consulta-item">
                    <span class="consulta-data">📅 14/05/2026 às 14:30</span>
                    <span class="consulta-medico">Dra. Ana Caroline — Reabilitação</span>
                    <span class="consulta-status status-concluida">✔ Concluída</span>
                </div>

                <div class="consulta-item">
                    <span class="consulta-data">📅 02/05/2026 às 09:00</span>
                    <span class="consulta-medico">Dr. Adolfo Martins — Osteopatia</span>
                    <span class="consulta-status status-concluida">✔ Concluída</span>
                </div>

                <div class="consulta-item">
                    <span class="consulta-data">📅 19/04/2026 às 11:00</span>
                    <span class="consulta-medico">Dr. Davi Vinciaqui — Esportiva</span>
                    <span class="consulta-status status-cancelada">✖ Cancelada</span>
                </div>

                <a href="index.html" class="btn-agendar-link">➕ Agendar Nova Sessão</a>
            </article>

        </div>
    </main>

</body>
</html>

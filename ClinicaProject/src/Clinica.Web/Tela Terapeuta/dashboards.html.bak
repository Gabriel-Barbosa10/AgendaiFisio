<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Agenda - AgendaiFisio</title>
    <!-- Importando Fonte Inter (Moderna) -->
    <link href="https://googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="dashboards.css">
    <link rel="stylesheet" href="../Tela de Agendamento/index.css">
</head>

<body>

    <div class="app-container">
        <!-- Sidebar Padrão -->
        <aside class="sidebar">
            <div class="sidebar-logo">🌿 AgendaiFisio</div>
            <nav>
                <a href="dashboards.html" class="active">📊 Dashboard</a>
                <a href="TelaTerapeuta.html">📅 Minha Agenda</a>
                <a href="pacientesTerapeuta.html">👥 Meus Pacientes</a>
            </nav>
            <div class="sidebar-user">
                <strong>Davi Gusmão</strong>
                <p>Terapeuta</p>
            </div>
        </aside>

        <!-- Área principal onde ficam os cards -->
        <main class="main-content">
            <header class="main-header">
                <div class="title-group">
                    <h1>Agenda Semanal</h1>
                    <p id="currentDate">Carregando calendário...</p>
                </div>
                <div class="header-actions">
                    <button class="btn-action-outline" id="btnVerPacientes" onclick="location.href='pacientesTerapeuta.html'">👥 Pacientes</button>
                    <button class="btn-novo" id="btnBloquearAgenda" onclick="document.getElementById('modalAgenda').showModal()">🔒 Bloquear Agenda</button>
                </div>
            </header>

            <!-- Estatísticas -->
            <section class="stats-grid">
                <div class="stat-card">
                    <span class="stat-label">Consultas Hoje</span>
                    <span class="stat-value"></span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Consultas Mês </span>
                    <span class="stat-value"></span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Atendidos Até Agora </span>
                    <span class="stat-value"></span>
                </div>
            </section>

            <!-- Lista de Consultas -->
            <section class="consultas-section">
                <h2>Próximos Atendimentos</h2>
                <div class="consultas-grid" id="gridConsultas">
                    <!-- Cards injetados via JS -->
                </div>
            </section>
        </main>

        <script src="dashboards.js"></script>
</body>

</html>